# Server
APP_ENV=development
SERVER_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=ganti_dengan_password_postgres_anda
DB_NAME=revocreative_cms
DB_SSLMODE=disable

# Session
SESSION_SECRET=ganti_dengan_string_acak_panjang_minimal_32_karakter
SESSION_COOKIE_NAME=revocms_session
SESSION_MAX_AGE_SECONDS=86400

# CORS (origin SPA frontend saat dev)
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Upload
UPLOAD_DIR=./uploads
UPLOAD_MAX_BYTES=5242880

# Seed admin user pertama (dipakai saat migrate pertama kali)
SEED_ADMIN_EMAIL=admin@revocreative.local
SEED_ADMIN_PASSWORD=ganti_dengan_password_admin_yang_kuat
