              "host": ["{{base_url}}"],
              "path": ["api", "admin", "products"]
            }
          }
        },
        {
          "name": "POST /api/admin/products",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
