              "raw": "{\n  \"title\": \"Company Profile + CMS (Updated)\",\n  \"slug\": \"company-profile-cms\",\n  \"description\": \"Update deskripsi...\",\n  \"thumbnail_path\": \"/uploads/products/cms-thumbnail.png\",\n  \"features\": [\"Custom Domain\", \"CMS Editor\"],\n  \"price\": \"Mulai Rp 4jt\",\n  \"display_order\": 1,\n  \"is_published\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/products/1",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "products", "1"]
