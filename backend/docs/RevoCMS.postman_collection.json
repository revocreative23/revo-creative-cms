          }
        },
        {
          "name": "DELETE /api/admin/products/:id",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/admin/products/1",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "products", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "POST /api/admin/upload (multipart)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": [],
                  "description": "Pilih file gambar (png, jpg, jpeg, webp, svg, gif, ico) max 5MB"
                },
                {
                  "key": "subdir",
                  "value": "logos",
                  "type": "text",
                  "description": "Optional: subfolder pengelompokan (logos / portfolio / products)"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/admin/upload",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "upload"]
            }
          }
        },
        {
          "name": "GET /uploads/<file> (public access)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/uploads/logos/GANTI-NAMA-FILE-DARI-UPLOAD",
              "host": ["{{base_url}}"],
              "path": ["uploads", "logos", "GANTI-NAMA-FILE-DARI-UPLOAD"]
            }
          }
        }
      ]
    }
  ]
}
